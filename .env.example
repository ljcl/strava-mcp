# Strava OAuth credentials (from strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Public URL for OAuth callback (e.g., https://strava-mcp.coelacanth-tuna.ts.net)
# Required for web-based OAuth flow
PUBLIC_URL=

# Optional: Initial tokens from setup-auth.ts (not needed if using web auth)
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=

# Optional: Path for exported routes
ROUTE_EXPORT_PATH=

# Optional: Override token storage directory (default: ./data)
TOKEN_DATA_DIR=
