{
  "name": "strava-mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "boundaries": "turbo boundaries",
    "check": "turbo run lint test typecheck build && turbo boundaries",
    "check:affected": "turbo run lint test typecheck build --affected && turbo boundaries",
    "build:affected": "turbo run build --affected",
    "typecheck:affected": "turbo run typecheck --affected",
    "knip": "knip",
    "storybook": "turbo run storybook --filter=@strava-mcp/storybook",
    "build-storybook": "turbo run build:storybook --filter=@strava-mcp/storybook"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "knip": "6.16.0",
    "turbo": "2.9.16"
  }
}
