{
  "name": "strava-mcp",
  "version": "2.7.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:stories": "vitest run --config vitest.stories.config.ts --project storybook",
    "test:stories:coverage": "vitest run --config vitest.stories.config.ts --project storybook --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "boundaries": "turbo boundaries",
    "check": "turbo run lint test typecheck build && turbo boundaries",
    "check:affected": "turbo run lint test typecheck build --affected && turbo boundaries",
    "build:affected": "turbo run build --affected",
    "typecheck:affected": "turbo run typecheck --affected",
    "knip": "knip",
    "storybook": "turbo run storybook --filter=@strava-mcp/storybook",
    "build-storybook": "turbo run build:storybook --filter=@strava-mcp/storybook",
    "coverage:summary": "bun scripts/coverage-summary.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@storybook/addon-vitest": "10.5.2",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "knip": "6.27.0",
    "playwright": "1.61.1",
    "turbo": "2.10.5",
    "vitest": "4.1.10"
  }
}
